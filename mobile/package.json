{
  "name": "myriad-mobile",
  "version": "1.0.0",
  "description": "Project Myriad Mobile App - Native mobile experience for manga, anime, and light novel management",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:android": "expo build:android",
    "build:ios": "expo build:ios",
    "build:web": "expo build:web",
    "eject": "expo eject",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --watchAll=false",
    "audit": "npm audit --audit-level moderate",
    "bundle:android": "expo export:embed --platform android",
    "bundle:ios": "expo export:embed --platform ios"
  },
  "keywords": [
    "manga",
    "anime",
    "light-novel",
    "reading-tracker",
    "library-management",
    "react-native",
    "expo",
    "mobile-app",
    "ios",
    "android"
  ],
  "author": "Project Myriad Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Project-Myriad/Project-Myriad.git",
    "directory": "mobile"
  },
  "bugs": {
    "url": "https://github.com/Project-Myriad/Project-Myriad/issues"
  },
  "homepage": "https://github.com/Project-Myriad/Project-Myriad#readme",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "expo": "^53.0.19",
    "react": "^18.2.0",
    "react-native": "^0.80.0",
    "expo-status-bar": "^1.0.0",
    "@react-navigation/native": "^6.1.9",
    "@react-navigation/stack": "^6.3.20",
    "@react-navigation/bottom-tabs": "^6.5.11",
    "@reduxjs/toolkit": "^2.0.1",
    "react-redux": "^9.0.4",
    "axios": "^1.6.2",
    "@tanstack/react-query": "^5.8.4",
    "react-hook-form": "^7.48.2",
    "expo-font": "^11.10.2",
    "expo-linear-gradient": "^12.7.2",
    "expo-secure-store": "^12.8.1",
    "expo-file-system": "^16.0.6",
    "expo-image": "^1.10.1",
    "expo-image-picker": "^14.7.1",
    "react-native-safe-area-context": "^5.0.0",
    "react-native-screens": "^3.29.0",
    "react-native-gesture-handler": "^2.14.1",
    "react-native-reanimated": "^3.6.2",
    "react-native-svg": "^14.1.0",
    "react-native-toast-message": "^2.2.0",
    "date-fns": "^2.30.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.5",
    "@types/react": "^18.2.39",
    "@types/react-native": "^0.73.0",
    "typescript": "^5.3.2",
    "eslint": "^8.55.0",
    "@typescript-eslint/eslint-plugin": "^6.13.1",
    "@typescript-eslint/parser": "^6.13.1",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-native": "^4.1.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.1.1",
    "jest": "^29.7.0",
    "@testing-library/react-native": "^12.4.2",
    "@testing-library/jest-native": "^5.4.3",
    "react-test-renderer": "^18.2.0",
    "metro-react-native-babel-preset": "^0.77.0",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.0"
  },
  "jest": {
    "testEnvironment": "node",
    "transformIgnorePatterns": [
      "node_modules/(?!(react-native|@react-native|expo|@expo|@unimodules|unimodules|sentry-expo|native-base|react-navigation))"
    ],
    "collectCoverageFrom": [
      "**/*.{js,jsx,ts,tsx}",
      "!**/node_modules/**",
      "!**/coverage/**",
      "!**/*.config.js",
      "!**/App.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 0,
        "functions": 0,
        "lines": 0,
        "statements": 0
      }
    }
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
