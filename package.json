{
  "name": "project-myriad",
  "version": "2.0.0",
  "description": "Projec    "health:check": "./scripts/health-check.sh", Myriad - Unified manga, anime, and light novel management platform with cross-platform React Native app",
  "private": true,
  "workspaces": [
    "backend",
    "mobile"
  ],
  "scripts": {
    "install:all": "npm install && npm run install:backend && npm run install:mobile",
    "install:backend": "cd backend && npm install",
    "install:mobile": "cd mobile && npm install --legacy-peer-deps",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:mobile\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:mobile": "cd mobile && npm start",
    "dev:web": "cd mobile && npm run web",
    "dev:android": "cd mobile && npm run android",
    "dev:ios": "cd mobile && npm run ios",
    "build": "npm run build:backend && npm run build:mobile",
    "build:backend": "cd backend && npm run build",
    "build:mobile": "cd mobile && npm run build:web && npm run build:android && npm run build:ios",
    "start": "concurrently \"npm run start:backend\" \"npm run start:mobile\"",
    "start:backend": "cd backend && npm start",
    "start:mobile": "cd mobile && npm start",
    "start:unified": "./scripts/start-unified-app.sh all",
    "commit": "./scripts/auto-commit.sh",
    "lint": "npm run lint:backend && npm run lint:mobile",
    "lint:backend": "cd backend && npm run lint",
    "lint:mobile": "cd mobile && npm run lint",
    "lint:fix": "npm run lint:fix:backend && npm run lint:fix:mobile",
    "lint:fix:backend": "cd backend && npm run lint:fix",
    "lint:fix:mobile": "cd mobile && npm run lint:fix",
    "format": "npm run format:backend && npm run format:mobile",
    "format:backend": "cd backend && npm run format",
    "format:mobile": "cd mobile && npm run format",
    "format:check": "npm run format:check:backend && npm run format:check:mobile",
    "format:check:backend": "cd backend && npm run format:check",
    "format:check:mobile": "cd mobile && npm run format:check",
    "test": "npm run test:backend && npm run test:mobile",
    "test:backend": "cd backend && npm test",
    "test:mobile": "cd mobile && npm test",
    "test:unit": "npm run test:unit:backend && npm run test:unit:mobile",
    "test:unit:backend": "cd backend && npm run test:unit",
    "test:unit:mobile": "cd mobile && npm run test:run",
    "test:integration": "cd backend && npm run test:integration",
    "test:coverage": "npm run test:backend -- --coverage && npm run test:mobile -- --coverage",
    "test:watch": "concurrently \"npm run test:backend -- --watch\" \"npm run test:mobile -- --watch\"",
    "audit": "npm audit && npm run audit:backend && npm run audit:mobile",
    "audit:backend": "cd backend && npm audit",
    "audit:mobile": "cd mobile && npm audit",
    "security": "npm run audit && npm run lint:security",
    "lint:security": "npm run lint:security:backend",
    "lint:security:backend": "cd backend && npm run lint:security",
    "clean": "npm run clean:backend && npm run clean:mobile",
    "clean:backend": "cd backend && rm -rf node_modules && rm -rf logs",
    "clean:mobile": "cd mobile && rm -rf node_modules && rm -rf .expo",
    "reset": "npm run clean && npm run install:all",
    "setup": "npm run install:all && npm run setup:env",
    "setup:env": "cp .env.example backend/.env && echo 'Please configure backend/.env with your settings'",
    "migrate": "cd backend && npm run migrate",
    "seed": "cd backend && npm run seed",
    "docker:build": "docker build -t project-myriad .",
    "docker:run": "docker run -p 3000:3000 -p 8081:8081 project-myriad",
    "docker:dev": "docker-compose up --build",
    "docker:stop": "docker-compose down",
    "analyze": "npm run analyze:mobile",
    "analyze:mobile": "cd mobile && npm run analyze:bundle",
    "analyze:deps": "cd mobile && npm run analyze:deps",
    "performance:test": "npm run performance:backend",
    "performance:backend": "cd backend && npm run performance:test",
    "release": "semantic-release",
    "precommit": "lint-staged",
    "prepare": "husky install",
    "deps:update": "npx npm-check-updates -u && npm install",
    "deps:check": "npx npm-check-updates",
    "health:check": "./scripts/health-check.sh"
  },
  "keywords": [
    "manga",
    "anime",
    "light-novel",
    "reading-tracker",
    "library-management",
    "monorepo",
    "nodejs",
    "react-native",
    "expo",
    "cross-platform",
    "unified-app",
    "express",
    "expo"
  ],
  "author": "Project Myriad Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Project-Myriad/Project-Myriad.git"
  },
  "bugs": {
    "url": "https://github.com/Project-Myriad/Project-Myriad/issues"
  },
  "homepage": "https://github.com/Project-Myriad/Project-Myriad#readme",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.0",
    "prettier": "^3.1.1"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,css,md}": [
      "prettier --write"
    ]
  }
}
