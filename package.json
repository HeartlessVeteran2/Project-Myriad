    "bcrypt": "^5.1.1",
    "fastify": "^4.0.0",
    "jsonwebtoken": "^9.0.2",
    "next": "^14.0.0",
    "pg": "^8.16.2",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "unzipper": "^0.10.14"
  }
