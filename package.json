{
  "name": "project-myriad",
  "version": "1.0.0",
  "description": "Project Myriad - Unified manga, anime, and light novel management platform",
  "private": true,
  "workspaces": [
    "backend",
    "frontend", 
    "mobile"
  ],
  "scripts": {
    "install:all": "npm install && npm run install:backend && npm run install:frontend && npm run install:mobile",
    "install:backend": "cd backend && npm install",
    "install:frontend": "cd frontend && npm install",
    "install:mobile": "cd mobile && npm install",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:mobile": "cd mobile && npm start",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "cd backend && npm run build",
    "build:frontend": "cd frontend && npm run build",
    "build:mobile": "cd mobile && npm run build:android && npm run build:ios",
    "start": "concurrently \"npm run start:backend\" \"npm run start:frontend\"",
    "start:backend": "cd backend && npm start",
    "start:frontend": "cd frontend && npm run preview",
    "start:mobile": "cd mobile && npm start",
    "commit": "./scripts/auto-commit.sh",
    "lint": "npm run lint:backend && npm run lint:frontend && npm run lint:mobile",
    "lint:backend": "cd backend && npm run lint",
    "lint:frontend": "cd frontend && npm run lint",
    "lint:mobile": "cd mobile && npm run lint",
    "lint:fix": "npm run lint:fix:backend && npm run lint:fix:frontend && npm run lint:fix:mobile",
    "lint:fix:backend": "cd backend && npm run lint:fix",
    "lint:fix:frontend": "cd frontend && npm run lint:fix", 
    "lint:fix:mobile": "cd mobile && npm run lint:fix",
    "format": "npm run format:backend && npm run format:frontend && npm run format:mobile",
    "format:backend": "cd backend && npm run format",
    "format:frontend": "cd frontend && npm run format",
    "format:mobile": "cd mobile && npm run format",
    "format:check": "npm run format:check:backend && npm run format:check:frontend && npm run format:check:mobile",
    "format:check:backend": "cd backend && npm run format:check",
    "format:check:frontend": "cd frontend && npm run format:check",
    "format:check:mobile": "cd mobile && npm run format:check",
    "test": "npm run test:backend && npm run test:frontend && npm run test:mobile",
    "test:backend": "cd backend && npm run test",
    "test:frontend": "cd frontend && npm run test:run",
    "test:mobile": "cd mobile && npm run test:ci",
    "test:unit": "npm run test:unit:backend && npm run test:unit:frontend",
    "test:unit:backend": "cd backend && npm run test:unit",
    "test:unit:frontend": "cd frontend && npm run test:run",
    "test:integration": "cd backend && npm run test:integration",
    "test:e2e": "cd e2e && npm test",
    "test:coverage": "npm run test:coverage:backend && npm run test:coverage:frontend && npm run test:coverage:mobile",
    "test:coverage:backend": "cd backend && npm run test:coverage",
    "test:coverage:frontend": "cd frontend && npm run test:coverage",
    "test:coverage:mobile": "cd mobile && npm run test:coverage",
    "test:watch": "concurrently \"npm run test:watch:backend\" \"npm run test:watch:frontend\"",
    "test:watch:backend": "cd backend && npm run test:watch",
    "test:watch:frontend": "cd frontend && npm run test:watch",
    "audit": "npm audit && npm run audit:backend && npm run audit:frontend && npm run audit:mobile",
    "audit:backend": "cd backend && npm run audit",
    "audit:frontend": "cd frontend && npm run audit", 
    "audit:mobile": "cd mobile && npm run audit",
    "security": "npm run audit && npm run lint:security",
    "lint:security": "npm run lint:security:backend",
    "lint:security:backend": "cd backend && npm run lint:security",
    "clean": "npm run clean:backend && npm run clean:frontend && npm run clean:mobile && npm run clean:root",
    "clean:backend": "cd backend && rm -rf node_modules dist coverage",
    "clean:frontend": "cd frontend && rm -rf node_modules dist build coverage",
    "clean:mobile": "cd mobile && rm -rf node_modules .expo dist",
    "clean:root": "rm -rf node_modules",
    "reset": "npm run clean && npm run install:all",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docs:build": "echo 'Building documentation...'",
    "docs:serve": "echo 'Serving documentation...'",
    "release": "npm run test && npm run build && npm run docs:build",
    "prepare": "husky install"
  },
  "keywords": [
    "manga",
    "anime", 
    "light-novel",
    "reading-tracker",
    "library-management",
    "monorepo",
    "nodejs",
    "react",
    "react-native",
    "express",
    "vite",
    "expo"
  ],
  "author": "Project Myriad Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Project-Myriad/Project-Myriad.git"
  },
  "bugs": {
    "url": "https://github.com/Project-Myriad/Project-Myriad/issues"
  },
  "homepage": "https://github.com/Project-Myriad/Project-Myriad#readme",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "husky": "^9.0.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.1.1"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,css,md}": [
      "prettier --write"
    ]
  }
}
