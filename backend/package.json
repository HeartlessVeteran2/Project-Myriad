{
  "name": "myriad-backend",
  "version": "1.0.0",
  "description": "Project Myriad Backend API - Unified manga, anime, and light novel management platform",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "build": "echo 'No build step required for Node.js'",
    "lint": "eslint . --ext .js,.mjs,.ts",
    "lint:fix": "eslint . --ext .js,.mjs,.ts --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "node -e \"console.log('JavaScript project - no TypeScript type checking needed')\"",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "jest --testPathPattern=unit",
    "test:integration": "jest --testPathPattern=integration",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "migrate": "node scripts/migrate.js",
    "migrate:rollback": "node scripts/migrate-rollback.js",
    "seed": "node scripts/seed.js",
    "audit": "npm audit --audit-level moderate",
    "security": "npm audit && npm run lint:security",
    "lint:security": "eslint . --ext .js,.mjs,.ts --config .eslintrc.security.js"
  },
  "keywords": [
    "manga",
    "anime",
    "light-novel",
    "library-management",
    "reading-tracker",
    "api",
    "backend",
    "nodejs",
    "express"
  ],
  "author": "Project Myriad Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Project-Myriad/Project-Myriad.git",
    "directory": "backend"
  },
  "bugs": {
    "url": "https://github.com/Project-Myriad/Project-Myriad/issues"
  },
  "homepage": "https://github.com/Project-Myriad/Project-Myriad#readme",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "express": "^4.19.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "dotenv": "^16.4.5",
    "bcrypt": "^5.1.1",
    "jsonwebtoken": "^9.0.2",
    "joi": "^17.11.0",
    "mysql2": "^3.6.5",
    "redis": "^4.6.12",
    "multer": "^2.0.1",
    "sharp": "^0.33.1",
    "rate-limiter-flexible": "^5.0.3",
    "compression": "^1.7.4"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-security": "^2.1.0",
    "prettier": "^3.1.1",
    "jest": "^29.7.0",
    "supertest": "^6.3.4",
    "@types/jest": "^29.5.8",
    "husky": "^8.0.3",
    "lint-staged": "^16.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "**/*.{js,mjs}",
      "!**/node_modules/**",
      "!**/coverage/**",
      "!**/tests/**",
      "!**/*.config.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 50,
        "functions": 50,
        "lines": 50,
        "statements": 50
      }
    }
  },
  "lint-staged": {
    "*.{js,mjs,ts}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
