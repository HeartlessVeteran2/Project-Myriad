# Environment Variables Configuration

# Database Configuration
DATABASE_URL=mongodb://localhost:27017/project-myriad
REDIS_URL=redis://localhost:6379

# Server Configuration
PORT=3000
NODE_ENV=development

# Security
JWT_SECRET=your-super-secret-jwt-key-change-this
CORS_ORIGIN=http://localhost:3000

# External APIs
GITHUB_TOKEN=your-github-token
DISCORD_WEBHOOK_URL=your-discord-webhook-url

# File Storage
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# Web3 Configuration
ETHEREUM_PROVIDER_URL=https://mainnet.infura.io/v3/your-project-id
POLYGON_PROVIDER_URL=https://polygon-mainnet.infura.io/v3/your-project-id

# Extension System
EXTENSIONS_PATH=./extensions
ALLOW_REMOTE_EXTENSIONS=false

# Community Features
ENABLE_FORUMS=true
ENABLE_USER_PROFILES=true
ENABLE_SOCIAL_FEATURES=true

# AI Features
ENABLE_RECOMMENDATIONS=true
RECOMMENDATION_MODEL=collaborative-filtering

# Accessibility
DEFAULT_FONT_SIZE=medium
ENABLE_HIGH_CONTRAST=false
ENABLE_TEXT_TO_SPEECH=false
